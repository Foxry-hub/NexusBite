generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  menus       Menu[]

  @@map("categories")
}

model User {
  id             String           @id @default(cuid())
  name           String
  email          String           @unique
  password       String
  role           Role             @default(SISWA)
  isApproved     Boolean          @default(false)
  balance        Int              @default(0)
  profilePhoto   String?          @db.LongText
  kelas          String?
  jurusan        String?
  tanggalLahir   DateTime?
  nis            String?          @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  balanceHistory BalanceHistory[]
  menus          Menu[]
  orderGroups    OrderGroup[]
  sellerOrders   Order[]          @relation("SellerOrders")
  orders         Order[]
  withdrawals    Withdrawal[]

  @@map("users")
}

model Menu {
  id          String      @id @default(cuid())
  name        String
  description String      @db.Text
  price       Int
  image       String?     @db.LongText
  status      MenuStatus  @default(AVAILABLE)
  sellerId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  seller      User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([sellerId])
  @@index([categoryId])
  @@map("menus")
}

model OrderGroup {
  id               String     @id @default(cuid())
  groupNumber      String     @unique
  userId           String
  totalAmount      Int
  pickupTime       PickupTime
  verificationCode String
  qrToken          String     @unique
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders           Order[]

  @@index([userId])
  @@index([qrToken])
  @@index([verificationCode])
  @@map("order_groups")
}

model Order {
  id           String      @id @default(cuid())
  orderGroupId String
  userId       String
  sellerId     String?
  totalAmount  Int
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]
  orderGroup   OrderGroup  @relation(fields: [orderGroupId], references: [id], onDelete: Cascade)
  seller       User?       @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderGroupId])
  @@index([userId])
  @@index([sellerId])
  @@map("orders")
}

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  menuId   String
  quantity Int
  menu     Menu   @relation(fields: [menuId], references: [id])
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuId])
  @@map("order_items")
}

model BalanceHistory {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  type      String   @default("TOP_UP")
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("balance_history")
}

model Withdrawal {
  id          String           @id @default(cuid())
  userId      String
  amount      Int
  status      WithdrawalStatus @default(PENDING)
  method      String           @default("CASH")
  note        String?          @db.Text
  adminNote   String?          @db.Text
  processedAt DateTime?
  processedBy String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  adminFee    Int              @default(0)
  netAmount   Int              @default(0)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("withdrawals")
}

enum Role {
  SISWA
  PENJUAL
  ADMIN
}

enum MenuStatus {
  AVAILABLE
  OUT_OF_STOCK
}

enum PickupTime {
  BREAK_1
  BREAK_2
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}
